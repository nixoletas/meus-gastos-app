# Copie este arquivo para ".env" e preencha com as chaves do seu projeto Supabase.
# Encontre esses valores em: Supabase > Project Settings > API
# IMPORTANTE: o prefixo EXPO_PUBLIC_ é obrigatório para o Expo expor a variável ao app.

EXPO_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica-aqui
